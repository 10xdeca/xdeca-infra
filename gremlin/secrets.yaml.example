telegram_bot_token: "your-telegram-bot-token"
kan_api_key: "your-kan-api-key"
kan_service_api_key: ""  # Service API key for Kan (fallback for kan_api_key)
claude_code_oauth_token: "your-claude-max-oauth-token"  # From `claude setup-token`
kan_base_url: "https://tasks.xdeca.com/api/v1"
outline_api_key: ""  # Optional — enables Outline wiki MCP tools
outline_base_url: "https://kb.xdeca.com/api"
sprint_start_date: "2025-01-05"
reminder_interval_hours: "1"
admin_user_ids: "123456789,987654321"  # Telegram user IDs for bot admins
radicale_password: ""  # Radicale password (enables calendar MCP tools)
playwright_enabled: ""  # Set to "true" to enable web browsing tools
contact_scanner_enabled: ""  # Set to "true" to enable background image scanning
github_token: ""  # Fine-grained PAT with contents:read (enables code reading tools)
gremlin_email: ""  # Gremlin's email address
gremlin_email_password: ""  # Gremlin's email password
gremlin_github_token: ""  # Gremlin's GitHub PAT (separate from code reading token)
